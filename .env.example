# Copiar a .env y completar. NUNCA commitear el .env real.

# --- Twilio (https://console.twilio.com) ---
TWILIO_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Groq (https://console.groq.com/keys — free tier) ---
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxx
# GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
# GROQ_TEXT_MODEL=llama-3.3-70b-versatile
# GROQ_WHISPER_MODEL=whisper-large-v3

# --- Anonimato: secreto del HMAC del teléfono (cualquier string largo y aleatorio) ---
HASH_SECRET=cambiar-por-un-secreto-largo-y-aleatorio

# --- URL pública del túnel (la imprime cloudflared al levantar; opcional pero recomendado) ---
# PUBLIC_URL=https://xxxx-yyyy.trycloudflare.com/

# --- Demo ---
SEED_DEMO=true
SESSION_TTL_MIN=120
TZ=America/Argentina/Buenos_Aires
